@page "/{*path:nonfile}"

<PageTitle>Soratus · Pagina niet gevonden</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex" />
</HeadContent>

<section class="end">
    <div class="wrap reveal in">
        <div class="sec-tag" style="justify-content:center">404 · Niet gevonden</div>
        <h2 class="h1" style="margin:18px 0 0">Dit hoort hier <span class="italic">niet</span>.</h2>
        <p>De pagina die je zocht bestaat (nog) niet. Ga terug naar de homepage, of stel je vraag aan onze agent.</p>
        <div class="end-cta">
            <a href="/" class="btn btn-primary">Terug naar home</a>
            <button class="btn" onclick="window.soratus && soratus.openChat()">Stel een vraag</button>
        </div>
    </div>
</section>
