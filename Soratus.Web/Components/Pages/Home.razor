@page "/"
@inject IOptions<CompanyOptions> Company
@inject IOptions<BrandOptions> Brand

<PageTitle>Soratus · Time-changing software</PageTitle>
<HeadContent>
    <meta name="description" content="Soratus bouwt AI-agents, custom software en integraties voor MKB en enterprise. Vaste prijs, in productie binnen 14 dagen. EU-hosted, AVG-proof." />
    <meta name="keywords" content="AI development, AI agents, custom software, Blazor, .NET 10, Azure, Nederland, MKB, enterprise, AVG, EU-hosted" />
    <meta name="author" content="@Company.Value.LegalName" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta property="og:title" content="Soratus · Time-changing software" />
    <meta property="og:description" content="AI-agents, custom software en integraties voor MKB en enterprise. Vaste prijs, in productie binnen 14 dagen." />
    <meta property="og:image" content="@(Company.Value.Url)/brand/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="@Company.Value.Url" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Soratus" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Soratus · Time-changing software" />
    <meta name="twitter:description" content="AI-agents, custom software en integraties voor MKB en enterprise. Vaste prijs, in productie binnen 14 dagen." />
    <meta name="twitter:image" content="@(Company.Value.Url)/brand/og-image.png" />

    <script type="application/ld+json">
        @((MarkupString)JsonLd.Build(Company.Value))
    </script>
</HeadContent>

<Hero />
<Marquee />
<WhatWeDo />
<HowWeWork />
<Branches />
<section id="bewijs" style="padding-top:0;padding-bottom:0">
    <Clients />
    <Testimonials />
</section>
<FinalCta />
